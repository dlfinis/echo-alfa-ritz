# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit secrets.
# The app validates these vars with Zod at boot and crashes with a clear
# error if either one is missing or malformed.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable key (formerly "anon key", deprecated naming). Safe to expose
# in the browser bundle. Format: sb_publishable_...
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key-here
