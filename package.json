{
  "name": "echo-alfa-ritz",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @echo-alfa-ritz/pwa dev",
    "build": "pnpm --filter @echo-alfa-ritz/pwa build",
    "preview": "pnpm --filter @echo-alfa-ritz/pwa preview",
    "test": "pnpm --filter @echo-alfa-ritz/shared test && pnpm --filter @echo-alfa-ritz/pwa test",
    "typecheck": "pnpm -r typecheck",
    "verify-schema": "pnpm --filter @echo-alfa-ritz/pwa exec tsx scripts/verify-schema.ts",
    "deploy": "pnpm build && pnpm --filter @echo-alfa-ritz/pwa exec wrangler pages deploy dist --project-name=echo-alfa-ritz --branch=main --commit-dirty=true"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "dotenv": "^16.4.0"
  }
}